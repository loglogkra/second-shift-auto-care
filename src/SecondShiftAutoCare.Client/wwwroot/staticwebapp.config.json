{
  "routes": [
    {
      "route": "/api/admin/*",
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin/requests"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/.auth/*",
      "/_framework/*",
      "/css/*",
      "/images/*",
      "/favicon.ico",
      "/manifest.webmanifest",
      "/service-worker.js",
      "/service-worker.published.js"
    ]
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:8.0"
  }
}
