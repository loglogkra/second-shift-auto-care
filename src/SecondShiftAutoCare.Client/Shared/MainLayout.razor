@inherits LayoutComponentBase
@inject StaticWebAppsAuthClient Auth
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary" Dense="false" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" Class="me-2" />
        <MudLink Href="/" Class="brand-link">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <BrandMark Class="brand-mark--appbar" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Class="brand-name"><span>2ND</span> Shift</MudText>
                    <MudText Typo="Typo.caption" Class="brand-subtitle">After-hours & weekend auto service</MudText>
                </MudStack>
            </MudStack>
        </MudLink>
        <MudSpacer />
        <MudButton Href="/request-service" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.EditCalendar" Class="top-cta">Request Service</MudButton>
        @if (_authState?.IsAuthenticated == true)
        {
            <MudText Typo="Typo.body2" Class="mx-3 d-none d-md-inline">@_authState.UserName</MudText>
            <MudButton OnClick="Logout" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small" StartIcon="@Icons.Material.Filled.Logout">Logout</MudButton>
        }
        else
        {
            <MudButton OnClick="Login" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small" StartIcon="@Icons.Material.Filled.Login" Class="ms-2">Login</MudButton>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Breakpoint="Breakpoint.Md" Variant="DrawerVariant.Responsive" Class="app-drawer">
        <MudDrawerHeader Class="drawer-header">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <BrandMark Class="brand-mark--drawer" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-700 drawer-brand"><span>2ND</span> Shift</MudText>
                        <MudText Typo="Typo.caption">Auto Care</MudText>
                    </MudStack>
                </MudStack>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">After-hours service</MudChip>
            </MudStack>
        </MudDrawerHeader>
        <NavMenu IsAdmin="@(_authState?.IsAdmin == true)" />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-5 py-md-8 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private AuthState? _authState;

    private readonly MudTheme _theme = new()
    {
        Palette = new Palette
        {
            Primary = "#44688E",
            Secondary = "#C8CDD2",
            Tertiary = "#5A7FA8",
            Background = "#0F1217",
            Surface = "#1B2028",
            AppbarBackground = "#0F1217",
            DrawerBackground = "#1B2028",
            TextPrimary = "#C8CDD2",
            TextSecondary = "#7F848B"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "14px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override async Task OnInitializedAsync()
    {
        _authState = await Auth.GetAuthStateAsync();
    }

    private void Login() => Navigation.NavigateTo("/.auth/login/aad?post_login_redirect_uri=/admin/requests", forceLoad: true);

    private void Logout() => Navigation.NavigateTo("/.auth/logout?post_logout_redirect_uri=/", forceLoad: true);
}
