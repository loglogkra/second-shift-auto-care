@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary" Dense="false" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" Class="me-2" />
        <MudLink Href="/" Class="brand-link">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <BrandMark Class="brand-mark--appbar" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Class="brand-name"><span>2ND</span> Shift</MudText>
                    <MudText Typo="Typo.caption" Class="brand-subtitle">After-hours & weekend auto service</MudText>
                </MudStack>
            </MudStack>
        </MudLink>
        <MudSpacer />
        <MudButton Href="/request-service" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.EditCalendar" Class="top-cta">Request Service</MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Breakpoint="Breakpoint.Md" Variant="DrawerVariant.Responsive" Class="app-drawer">
        <MudDrawerHeader Class="drawer-header">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <BrandMark Class="brand-mark--drawer" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-700 drawer-brand"><span>2ND</span> Shift</MudText>
                        <MudText Typo="Typo.caption">Auto Care</MudText>
                    </MudStack>
                </MudStack>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">After-hours service</MudChip>
            </MudStack>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-5 py-md-8 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        Palette = new Palette
        {
            Primary = "#0B1D3A",
            Secondary = "#F5A623",
            Tertiary = "#00B2C7",
            Background = "#f7f8fa",
            Surface = "#ffffff",
            AppbarBackground = "#0B1D3A",
            DrawerBackground = "#ffffff",
            TextPrimary = "#2B2F36",
            TextSecondary = "#7B8794"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "14px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
