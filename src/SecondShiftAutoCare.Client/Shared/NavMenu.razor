<MudNavMenu Class="px-2 nav-menu" Bordered="false">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    <MudNavLink Href="/request-service" Icon="@Icons.Material.Filled.Handyman">Request Service</MudNavLink>
    @if (IsAdmin)
    {
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.overline" Class="px-4 nav-section">Admin</MudText>
        <MudNavLink Href="/admin/requests" Icon="@Icons.Material.Filled.Speed">Requests Board</MudNavLink>
    }
</MudNavMenu>

@code {
    [Parameter]
    public bool IsAdmin { get; set; }
}
