<MudPaper Elevation="0" Class="loading-card pa-5" role="status" aria-live="polite">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
            <div>
                <MudText Typo="Typo.h6">@Text</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@SubText</MudText>
            </div>
        </MudStack>
        @if (Skeleton == "Dashboard")
        {
            <MudGrid Spacing="2">
                @for (var i = 0; i < 4; i++) { <MudItem xs="6" md="3"><MudSkeleton Height="86px" Class="rounded-skeleton" /></MudItem> }
                @for (var i = 0; i < 3; i++) { <MudItem xs="12"><MudSkeleton Height="58px" Class="rounded-skeleton" /></MudItem> }
            </MudGrid>
        }
        else if (Skeleton == "Detail")
        {
            @foreach (var label in new[] { "Customer", "Vehicle", "Request", "Quote" })
            { <MudSkeleton Height="76px" Class="rounded-skeleton" /> }
        }
        @if (ShowTimeout)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">This is taking longer than expected. Refresh or try again.</MudAlert>
            @if (OnRetry.HasDelegate) { <MudButton OnClick="OnRetry" Color="Color.Primary" Variant="Variant.Filled">Retry</MudButton> }
        }
    </MudStack>
</MudPaper>
@code { [Parameter] public string Text { get; set; } = "Loading..."; [Parameter] public string SubText { get; set; } = "Getting things ready."; [Parameter] public string? Skeleton { get; set; } [Parameter] public bool ShowTimeout { get; set; } [Parameter] public EventCallback OnRetry { get; set; } }
