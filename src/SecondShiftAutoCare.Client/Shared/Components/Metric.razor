</MudItem>
@code { [Parameter] public string Title { get; set; } = "Metric"; [Parameter] public string Value { get; set; } = "0"; [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info; [Parameter] public string Accent { get; set; } = "teal"; }
