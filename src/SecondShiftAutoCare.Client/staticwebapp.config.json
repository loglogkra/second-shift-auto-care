{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/css/*", "/_framework/*"]
  },
  "routes": [
    {
      "route": "/admin/login",
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin/dashboard",
      "statusCode": 302
    },
    {
      "route": "/admin/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/",
      "statusCode": 302
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/admin/*",
      "allowedRoles": ["admin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/admin/login",
      "statusCode": 302
    }
  }
}
