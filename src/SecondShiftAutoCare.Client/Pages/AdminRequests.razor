@page "/admin/requests"
@page "/admin/dashboard"
@inject ServiceRequestClient ServiceRequests
@inject StaticWebAppsAuthClient Auth
<PageTitle>Admin Dashboard</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap" Spacing="2">
    <div>
        <MudText Typo="Typo.overline" Color="Color.Primary">Admin job board</MudText>
        <MudText Typo="Typo.h4">Admin Dashboard</MudText>
    </div>
    <MudSpacer />
    @if (_currentUser is not null)
    {
        <MudText Typo="Typo.body2" Class="mr-2">Signed in as @_currentUser.UserDetails</MudText>
    }
    <MudButton Href="/admin/logout" Color="Color.Secondary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Logout">Logout</MudButton>
</MudStack>

@if (_isLoading)
{
    <MudPaper Class="pa-6 text-center" Elevation="0"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><MudText Class="mt-3">Loading requests...</MudText></MudPaper>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" md="3"><MudCard Elevation="0" Class="board-stat"><MudCardContent><MudText Typo="Typo.h4">@FilteredRequests.Count()</MudText><MudText Typo="Typo.body2">Showing</MudText></MudCardContent></MudCard></MudItem>
        <MudItem xs="6" md="3"><MudCard Elevation="0" Class="board-stat"><MudCardContent><MudText Typo="Typo.h4">@Requests.Count(r => r.Status == ServiceRequestStatuses.New)</MudText><MudText Typo="Typo.body2">New</MudText></MudCardContent></MudCard></MudItem>
        <MudItem xs="6" md="3"><MudCard Elevation="0" Class="board-stat"><MudCardContent><MudText Typo="Typo.h4">@Requests.Count(r => r.Status == ServiceRequestStatuses.Scheduled)</MudText><MudText Typo="Typo.body2">Scheduled</MudText></MudCardContent></MudCard></MudItem>
        <MudItem xs="6" md="3"><MudCard Elevation="0" Class="board-stat"><MudCardContent><MudText Typo="Typo.h4">@Requests.Count(r => r.Status == ServiceRequestStatuses.PartsOrdered)</MudText><MudText Typo="Typo.body2">Parts Ordered</MudText></MudCardContent></MudCard></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mb-4" Elevation="0">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_searchText" Label="Search customer, phone, vehicle, service" Variant="Variant.Outlined" Immediate="true" /></MudItem>
            <MudItem xs="12" md="3"><MudSelect @bind-Value="_statusFilter" Label="Filter by status" Variant="Variant.Outlined"><MudSelectItem Value="@("All")">All</MudSelectItem>@foreach (var status in ServiceRequestStatuses.All) { <MudSelectItem Value="@status">@status</MudSelectItem> }</MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudSelect @bind-Value="_quickFilter" Label="Quick filter" Variant="Variant.Outlined"><MudSelectItem Value="@("All")">All</MudSelectItem><MudSelectItem Value="@("Today")">Today's jobs</MudSelectItem><MudSelectItem Value="@("Weekend")">This weekend's jobs</MudSelectItem><MudSelectItem Value="@("NeedsQuote")">Needs quote</MudSelectItem><MudSelectItem Value="@("WaitingCustomer")">Waiting on customer</MudSelectItem><MudSelectItem Value="@("WaitingParts")">Waiting on parts</MudSelectItem><MudSelectItem Value="@("CompletedMonth")">Completed this month</MudSelectItem></MudSelect></MudItem>
            <MudItem xs="12" md="2"><MudSwitch @bind-Value="_sortNewestFirst" Color="Color.Primary" Label="Newest first" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="FilteredRequests" Hover="true" Breakpoint="Breakpoint.Sm" Class="job-board" Elevation="0">
        <HeaderContent>
            <MudTh>Status</MudTh><MudTh>Customer</MudTh><MudTh>Phone</MudTh><MudTh>Email</MudTh><MudTh>Vehicle</MudTh><MudTh>Requested Service</MudTh><MudTh>Preferred Time</MudTh><MudTh>Created</MudTh><MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Status">
                <MudSelect T="string" Value="@context.Status" ValueChanged="@(status => UpdateStatusAsync(context, status))" Dense="true" Variant="Variant.Outlined">
                    @foreach (var status in DashboardStatuses)
                    {
                        <MudSelectItem Value="@status">@status</MudSelectItem>
                    }
                </MudSelect>
            </MudTd>
            <MudTd DataLabel="Customer"><MudText Typo="Typo.subtitle2">@context.CustomerName</MudText></MudTd>
            <MudTd DataLabel="Phone">@context.Phone</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Vehicle">@context.VehicleYear @context.VehicleMake @context.VehicleModel</MudTd>
            <MudTd DataLabel="Requested Service">@context.ServiceType</MudTd>
            <MudTd DataLabel="Preferred Time">@context.PreferredAvailability</MudTd>
            <MudTd DataLabel="Created">@context.CreatedAtUtc?.ToLocalTime().ToString("g")</MudTd>
            <MudTd><MudButton Href="@($"/admin/requests/{context.Id}")" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">Open</MudButton></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">No service requests yet.</MudAlert>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private List<ServiceRequestDto> Requests { get; set; } = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private ClientPrincipal? _currentUser;
    private string _searchText = string.Empty;
    private string _statusFilter = "All";
    private string _quickFilter = "All";
    private bool _sortNewestFirst = true;

    private static readonly string[] DashboardStatuses = [ServiceRequestStatuses.New, ServiceRequestStatuses.Contacted, ServiceRequestStatuses.Scheduled, ServiceRequestStatuses.Completed, ServiceRequestStatuses.Declined];

    private IEnumerable<ServiceRequestDto> FilteredRequests => ApplyFilters();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _currentUser = await Auth.GetCurrentUserAsync();
            var requests = await ServiceRequests.GetAllAsync();
            Requests = requests.OrderByDescending(request => request.CreatedAtUtc).ToList();
        }
        catch (Exception ex) when (ex is HttpRequestException or InvalidOperationException or JsonException)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<ServiceRequestDto> ApplyFilters()
    {
        var query = Requests.AsEnumerable();
        if (_statusFilter != "All") query = query.Where(r => r.Status == _statusFilter);
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(r => $"{r.CustomerName} {r.Phone} {r.VehicleYear} {r.VehicleMake} {r.VehicleModel} {r.ServiceType}".Contains(_searchText, StringComparison.OrdinalIgnoreCase));
        }
        query = _quickFilter switch
        {
            "NeedsQuote" => query.Where(r => r.Status == ServiceRequestStatuses.New || r.Status == ServiceRequestStatuses.NeedInfo),
            "WaitingCustomer" => query.Where(r => r.Status == ServiceRequestStatuses.NeedInfo || r.Status == ServiceRequestStatuses.Quoted),
            "WaitingParts" => query.Where(r => r.Status == ServiceRequestStatuses.PartsOrdered),
            "CompletedMonth" => query.Where(r => (r.Status == ServiceRequestStatuses.Completed || r.Status == ServiceRequestStatuses.Paid) && r.CreatedAtUtc?.Month == DateTime.Now.Month && r.CreatedAtUtc?.Year == DateTime.Now.Year),
            "Today" => query.Where(r => r.PreferredAvailability?.Contains("today", StringComparison.OrdinalIgnoreCase) == true || r.CreatedAtUtc?.ToLocalTime().Date == DateTime.Today),
            "Weekend" => query.Where(r => r.PreferredAvailability?.Contains("weekend", StringComparison.OrdinalIgnoreCase) == true || r.PreferredAvailability?.Contains("saturday", StringComparison.OrdinalIgnoreCase) == true || r.PreferredAvailability?.Contains("sunday", StringComparison.OrdinalIgnoreCase) == true),
            _ => query
        };
        return _sortNewestFirst ? query.OrderByDescending(r => r.CreatedAtUtc) : query.OrderBy(r => r.CreatedAtUtc);
    }

    private async Task UpdateStatusAsync(ServiceRequestDto request, string status)
    {
        if (request.Id is null || request.Status == status)
        {
            return;
        }

        try
        {
            var updated = await ServiceRequests.UpdateStatusAsync(request.Id.Value, new ServiceRequestStatusUpdateModel { Status = status });
            var index = Requests.FindIndex(r => r.Id == request.Id);
            if (index >= 0)
            {
                Requests[index] = updated;
            }
        }
        catch (Exception ex) when (ex is HttpRequestException or InvalidOperationException or JsonException)
        {
            _errorMessage = ex.Message;
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        ServiceRequestStatuses.New => Color.Info,
        ServiceRequestStatuses.Contacted => Color.Primary,
        ServiceRequestStatuses.NeedInfo => Color.Warning,
        ServiceRequestStatuses.Quoted => Color.Primary,
        ServiceRequestStatuses.Scheduled => Color.Secondary,
        ServiceRequestStatuses.PartsOrdered => Color.Tertiary,
        ServiceRequestStatuses.InProgress => Color.Warning,
        ServiceRequestStatuses.Completed => Color.Success,
        ServiceRequestStatuses.Paid => Color.Success,
        ServiceRequestStatuses.Declined => Color.Error,
        ServiceRequestStatuses.Canceled => Color.Error,
        _ => Color.Default
    };
}
