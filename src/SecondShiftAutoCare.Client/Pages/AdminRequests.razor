@page "/admin/requests"
@inject HttpClient Http
<PageTitle>Admin Requests</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Admin Requests</MudText>

@if (_isLoading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
}
else
{
    <MudTable Items="Requests" Hover="true">
        <HeaderContent>
            <MudTh>Status</MudTh><MudTh>Customer</MudTh><MudTh>Vehicle</MudTh><MudTh>Service</MudTh><MudTh>Created</MudTh><MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Status</MudTd>
            <MudTd>@context.CustomerName</MudTd>
            <MudTd>@context.VehicleYear @context.VehicleMake @context.VehicleModel</MudTd>
            <MudTd>@context.ServiceType</MudTd>
            <MudTd>@context.CreatedAtUtc?.ToLocalTime().ToString("g")</MudTd>
            <MudTd><MudLink Href="@($"/admin/requests/{context.Id}")">View</MudLink></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No service requests yet.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private List<ServiceRequestDto> Requests { get; set; } = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var response = await Http.GetAsync("api/admin/service-requests");
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Unable to load service requests. Please make sure the service request API is running.";
                return;
            }

            var requests = await response.Content.ReadFromJsonAsync<List<ServiceRequestDto>>();
            Requests = requests?.OrderByDescending(request => request.CreatedAtUtc).ToList() ?? [];
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to load service requests. Please try again.";
        }
        catch (JsonException)
        {
            _errorMessage = "The service request API returned an unexpected response. Please make sure the API is running and reachable at /api/admin/service-requests.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
