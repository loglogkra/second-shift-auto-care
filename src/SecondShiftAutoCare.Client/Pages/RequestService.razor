@page "/request-service"
@inject ServiceRequestClient ServiceRequests
@inject VehicleCatalogService VehicleCatalog
@inject NavigationManager Navigation
<PageTitle>Request Service</PageTitle>

<MudGrid Spacing="4">
    <MudItem xs="12" lg="4">
        <MudPaper Class="pa-5 sticky-panel" Elevation="0">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Place">Zeeland / West Michigan</MudChip>
            <MudText Typo="Typo.h4" Class="mt-3" GutterBottom="true">Request Service</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">Tell us about the vehicle, the issue, and the best after-hours or weekend windows for follow-up.</MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">Submitting this form does not approve repairs. We will contact you first.</MudAlert>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" lg="8">
        <MudCard Elevation="0" Class="form-card">
            <MudCardContent>
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                }
                <EditForm Model="Model" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <MudStack Spacing="4">
                        <section>
                            <MudText Typo="Typo.h6" Class="mb-3">Contact</MudText>
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6"><MudTextField @bind-Value="Model.CustomerName" Label="Customer name" For="@(() => Model.CustomerName)" Required="true" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField @bind-Value="Model.Phone" Label="Phone" For="@(() => Model.Phone)" Required="true" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12"><MudTextField @bind-Value="Model.Email" Label="Email (optional)" For="@(() => Model.Email)" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                            </MudGrid>
                        </section>
                        <MudDivider />
                        <section>
                            <MudText Typo="Typo.h6" Class="mb-3">Vehicle</MudText>
                            <MudGrid Spacing="3">
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="string" Value="Model.VehicleMake" ValueChanged="OnMakeChanged" Label="Make" For="@(() => Model.VehicleMake)" Required="true" Disabled="_isSubmitting || Model.VehicleYear is null" Variant="Variant.Outlined">
                                        @foreach (var make in AvailableMakes)
                                        {
                                            <MudSelectItem Value="@make">@make</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudSelect T="string" @bind-Value="Model.VehicleModel" Label="Model" For="@(() => Model.VehicleModel)" Required="true" Disabled="_isSubmitting || string.IsNullOrWhiteSpace(Model.VehicleMake)" Variant="Variant.Outlined">
                                        @foreach (var model in AvailableModels)
                                        {
                                            <MudSelectItem Value="@model">@model</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3"><MudNumericField @bind-Value="Model.Mileage" Label="Mileage (optional)" For="@(() => Model.Mileage)" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                            </MudGrid>
                        </section>
                        <MudDivider />
                        <section>
                            <MudText Typo="Typo.h6" Class="mb-3">Service details</MudText>
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" MultiSelection="true" SelectedValues="_selectedServices" SelectedValuesChanged="OnSelectedServicesChanged" Label="What service do you need?" Required="true" Disabled="_isSubmitting" Variant="Variant.Outlined" HelperText="Choose multiple services or Not Sure / Diagnose It.">
                                        @foreach (var serviceType in ServiceTypeOptions.All)
                                        {
                                            <MudSelectItem Value="@serviceType">@serviceType</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect @bind-Value="Model.UrgencyLevel" Label="Urgency" For="@(() => Model.UrgencyLevel)" Required="true" Disabled="_isSubmitting" Variant="Variant.Outlined">
                                        @foreach (var urgency in ServiceRequestUrgencyLevels.All)
                                        {
                                            <MudSelectItem Value="@urgency">@urgency</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect @bind-Value="Model.IsVehicleDrivable" Label="Is the vehicle drivable?" For="@(() => Model.IsVehicleDrivable)" Required="true" Disabled="_isSubmitting" Variant="Variant.Outlined">
                                        <MudSelectItem Value="@("Yes")">Yes</MudSelectItem><MudSelectItem Value="@("No")">No</MudSelectItem><MudSelectItem Value="@("Unsure")">Unsure</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12"><MudTextField @bind-Value="Model.VehicleLocation" Label="Where is the vehicle located?" For="@(() => Model.VehicleLocation)" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField @bind-Value="Model.PreferredAvailability" Label="Preferred availability" Placeholder="Weeknights after 6, Saturday morning..." For="@(() => Model.PreferredAvailability)" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12">
                                    @if (_intakeQuestions.Count > 0)
                                    {
                                        <MudPaper Class="pa-3 info-panel" Elevation="0">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2">Service-specific questions</MudText>
                                            @foreach (var question in _intakeQuestions)
                                            {
                                                <MudTextField Value="@GetAnswer(question.Id)" ValueChanged="@((string? value) => SetAnswer(question, value))" Label="@question.QuestionText" HelperText="@question.HelpText" Variant="Variant.Outlined" Class="mb-2" Disabled="_isSubmitting" />
                                            }
                                        </MudPaper>
                                    }
                                </MudItem>
                                <MudItem xs="12"><MudTextField @bind-Value="Model.Symptoms" Label="Symptoms / notes (optional)" HelperText="Optional: include noises, warning lights, when it started, or recent work." For="@(() => Model.Symptoms)" Lines="6" Disabled="_isSubmitting" Variant="Variant.Outlined" /></MudItem>
                            </MudGrid>
                            <MudCheckBox @bind-Value="Model.WantsPhotoUploadLater" Label="I may upload photos later if requested" Disabled="_isSubmitting" />
                            <MudCheckBox @bind-Value="Model.ConsentAccepted" Label="I understand this request is for scheduling/quoting only and does not authorize repairs." Required="true" Disabled="_isSubmitting" />
                        </section>
                        <ValidationSummary />
                        <MudStack Row="true" Justify="Justify.FlexEnd" Class="flex-wrap">
                            <MudButton Href="/" Color="Color.Primary" Variant="Variant.Text" Disabled="_isSubmitting">Cancel</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large" Disabled="_isSubmitting" StartIcon="@Icons.Material.Filled.Send">
                                @if (_isSubmitting)
                                {
                                    <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" />
                                    <span>Submitting...</span>
                                }
                                else
                                {
                                    <span>Submit request</span>
                                }
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </EditForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private ServiceRequestCreateModel Model { get; } = new();
    private bool _isSubmitting;
    private string? _errorMessage;
    private HashSet<string> _selectedServices = [];
    private IReadOnlyList<string> AvailableMakes => VehicleCatalog.GetMakes(Model.VehicleYear);
    private IReadOnlyList<string> AvailableModels => VehicleCatalog.GetModels(Model.VehicleYear, Model.VehicleMake);
    private List<ServiceIntakeQuestionDto> _intakeQuestions = [];
    private readonly Dictionary<Guid, string?> _answers = [];

    private void OnYearChanged(int? year)
    {
        Model.VehicleYear = year;
        if (!AvailableModels.Contains(Model.VehicleModel))
        {
            Model.VehicleModel = string.Empty;
        }
    }

    private void OnMakeChanged(string make)
    {
        Model.VehicleMake = make;
        Model.VehicleModel = string.Empty;
    }

    private async Task OnSelectedServicesChanged(IEnumerable<string> services)
    {
        _selectedServices = services.ToHashSet();
        Model.ServiceType = string.Join(", ", _selectedServices);
        var first = _selectedServices.FirstOrDefault();
        _intakeQuestions = string.IsNullOrWhiteSpace(first) ? [] : await ServiceRequests.GetQuestionsAsync(first);
        _answers.Clear();
    }

    private string? GetAnswer(Guid id) => _answers.TryGetValue(id, out var value) ? value : null;
    private void SetAnswer(ServiceIntakeQuestionDto question, string? value) 
    { 
        if (value == null)
        {
            _answers.Remove(question.Id);
        }
        else
        {
            _answers[question.Id] = value;
        }
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            Model.IntakeAnswers = _intakeQuestions.Select(q => new ServiceIntakeAnswerDto { QuestionId = q.Id, QuestionText = q.QuestionText, AnswerText = GetAnswer(q.Id) }).ToList();
            Model.ServiceSpecificAnswers = string.Join(Environment.NewLine, Model.IntakeAnswers.Where(a => !string.IsNullOrWhiteSpace(a.AnswerText)).Select(a => $"{a.QuestionText}: {a.AnswerText}"));
            var created = await ServiceRequests.CreateAsync(Model);
            Navigation.NavigateTo($"/request-submitted?token={created.PublicStatusToken}");
            return;
        }
        catch (Exception ex) when (ex is HttpRequestException or InvalidOperationException)
        {
            _errorMessage = $"We could not reach the service request API. Please try again in a few minutes. Details: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
