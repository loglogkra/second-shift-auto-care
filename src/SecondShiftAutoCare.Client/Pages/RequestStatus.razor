@page "/request-status/{Token}"
@inject ServiceRequestClient ServiceRequests
<PageTitle>Request Status</PageTitle>
@if (_loading) { <MudProgressCircular Indeterminate="true" /> } else if (_status is null) { <MudAlert Severity="Severity.Error">Status link was not found.</MudAlert> } else {
<MudCard Elevation="0" Class="pa-4"><MudCardContent><MudText Typo="Typo.overline" Color="Color.Primary">@_status.BusinessName</MudText><MudText Typo="Typo.h4">Request status</MudText><MudChip T="string" Color="Color.Primary" Class="my-3">@_status.Status</MudChip><MudList T="string"><MudListItem>Vehicle: @_status.Vehicle</MudListItem><MudListItem>Service: @_status.ServiceType</MudListItem><MudListItem>Submitted: @_status.SubmittedUtc.ToLocalTime().ToString("g")</MudListItem>@if (_status.ScheduledStartUtc is not null) { <MudListItem>Scheduled: @_status.ScheduledStartUtc.Value.ToLocalTime().ToString("g") @(_status.ScheduledEndUtc is not null ? $"- {_status.ScheduledEndUtc.Value.ToLocalTime():t}" : "")</MudListItem> }@if (_status.EstimateLow is not null || _status.EstimateHigh is not null || _status.TotalEstimate is not null) { <MudListItem>Estimate: @FormatEstimate()</MudListItem> }<MudListItem>Quote approval: @_status.CustomerApprovalStatus</MudListItem></MudList><MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">@_status.NextStepMessage</MudAlert></MudCardContent></MudCard> }
@code { [Parameter] public string Token { get; set; }=string.Empty; private bool _loading=true; private PublicRequestStatusDto? _status; protected override async Task OnInitializedAsync(){ try{ _status=await ServiceRequests.GetPublicStatusAsync(Token);} finally{_loading=false;} } private string FormatEstimate()=>_status?.TotalEstimate is not null ? $"{_status.TotalEstimate:C0}" : _status?.EstimateLow is not null && _status.EstimateHigh is not null ? $"{_status.EstimateLow:C0}–{_status.EstimateHigh:C0}" : "TBD"; }
