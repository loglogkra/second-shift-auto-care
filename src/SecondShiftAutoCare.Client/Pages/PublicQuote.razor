@page "/quote/{Token}"
@inject ServiceRequestClient ServiceRequests
<PageTitle>Quote Review</PageTitle>
@if (_loading) { <MudProgressCircular Indeterminate="true" /> } else if (_quote is null) { <MudAlert Severity="Severity.Error">Quote link was not found.</MudAlert> } else {
<MudCard Elevation="0" Class="pa-4"><MudCardContent><MudText Typo="Typo.h4">Review your quote</MudText><MudText>@_quote.Vehicle • @_quote.ServiceType</MudText><MudText Typo="Typo.h5" Class="my-3">@FormatEstimate()</MudText>@if(!string.IsNullOrWhiteSpace(_quote.GoodOption)){<MudAlert Severity="Severity.Info">Good: @_quote.GoodOption</MudAlert>}@if(!string.IsNullOrWhiteSpace(_quote.BetterOption)){<MudAlert Severity="Severity.Info">Better: @_quote.BetterOption</MudAlert>}@if(!string.IsNullOrWhiteSpace(_quote.BestOption)){<MudAlert Severity="Severity.Info">Best: @_quote.BestOption</MudAlert>}<MudText Class="my-3">@_quote.AssumptionDisclaimerText</MudText>@if(_quote.ScheduledStartUtc is not null){<MudText>Availability: @_quote.ScheduledStartUtc.Value.ToLocalTime().ToString("g")</MudText>}<MudDivider Class="my-4"/><MudTextField @bind-Value="_message" Label="Optional message" Lines="3" Variant="Variant.Outlined"/><MudStack Row="true" Class="mt-3 flex-wrap"><MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="() => Decide(ServiceRequestApprovalStatuses.Approved)">Approve</MudButton><MudButton Color="Color.Error" Variant="Variant.Outlined" OnClick="() => Decide(ServiceRequestApprovalStatuses.Declined)">Decline</MudButton><MudButton Color="Color.Warning" Variant="Variant.Outlined" OnClick="() => Decide(ServiceRequestApprovalStatuses.Question)">Ask a question</MudButton></MudStack>@if(!string.IsNullOrWhiteSpace(_saved)){<MudAlert Severity="Severity.Success" Class="mt-3">@_saved</MudAlert>}</MudCardContent></MudCard> }
@code { [Parameter] public string Token { get; set; }=string.Empty; private bool _loading=true; private PublicQuoteDto? _quote; private string? _message; private string? _saved; protected override async Task OnInitializedAsync(){ try{ _quote=await ServiceRequests.GetPublicQuoteAsync(Token);} finally{_loading=false;} } private async Task Decide(string d){ _quote=await ServiceRequests.SaveQuoteDecisionAsync(Token,new QuoteDecisionModel{Decision=d,Message=_message}); _saved=$"Response saved: {d}"; } private string FormatEstimate()=>_quote?.TotalEstimate is not null ? $"{_quote.TotalEstimate:C0}" : _quote?.EstimateLow is not null && _quote.EstimateHigh is not null ? $"{_quote.EstimateLow:C0}–{_quote.EstimateHigh:C0}" : "TBD"; }
