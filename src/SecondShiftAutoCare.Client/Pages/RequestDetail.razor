@page "/admin/requests/{RequestId:guid}"
@inject ServiceRequestClient ServiceRequests
@inject StaticWebAppsAuthClient Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS
<PageTitle>Request Detail</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap" Spacing="2">
    <MudButton Href="/admin/requests" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack">Back to board</MudButton>
    <MudSpacer />
    @if (_request is not null)
    {
        <MudChip T="string" Color="GetStatusColor(_request.Status)" Variant="Variant.Filled">@_request.Status</MudChip>
    }
</MudStack>

@if (_isLoading)
{
    <MudPaper Class="pa-6 text-center" Elevation="0"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><MudText Class="mt-3">Loading request...</MudText></MudPaper>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
}
else if (_authState?.IsAuthenticated != true)
{
    <MudCard Elevation="0" Class="pa-4">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">Admin sign in required</MudText>
            <MudText Class="mb-4">Please sign in with Microsoft before loading this admin request.</MudText>
            <MudButton OnClick="Login" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Login">Sign in with Microsoft</MudButton>
        </MudCardContent>
    </MudCard>
}
else if (!_authState.IsAdmin)
{
    <MudCard Elevation="0" Class="pa-4">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">Access denied</MudText>
            <MudText Class="mb-4">You are signed in but do not have admin access.</MudText>
            <MudButton OnClick="Logout" Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Logout">Sign out</MudButton>
        </MudCardContent>
    </MudCard>
}
else if (_request is not null)
{
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">@_successMessage</MudAlert>
    }

    <MudGrid Spacing="4">
        <MudItem xs="12" lg="5">
            <MudCard Elevation="0" Class="detail-card">
                <MudCardContent>
                    <MudText Typo="Typo.overline" Color="Color.Primary">Customer</MudText>
                    <MudText Typo="Typo.h4" GutterBottom="true"><MudLink Href="@($"/admin/customers/{_request.CustomerId}")">@_request.CustomerName</MudLink></MudText>
                    <MudStack Spacing="2">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Icon="@Icons.Material.Filled.Phone">@_request.Phone @(!string.IsNullOrWhiteSpace(_request.Email) ? $"• {_request.Email}" : string.Empty)</MudAlert>
                        <MudPaper Class="pa-3 info-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Vehicle</MudText>
                            <MudText><MudLink Href="@($"/admin/vehicles/{_request.VehicleId}")">@_request.VehicleYear @_request.VehicleMake @_request.VehicleModel</MudLink> @(_request.Mileage is not null ? $"• {_request.Mileage:N0} miles" : string.Empty)</MudText>
                        </MudPaper>
                        <MudPaper Class="pa-3 info-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Request</MudText>
                            <MudText>@_request.ServiceType</MudText>
                            <MudText Typo="Typo.caption">Urgency: @_request.UrgencyLevel • Drivable: @(_request.IsVehicleDrivable ?? "Not provided")</MudText>
                        </MudPaper>
                        <MudPaper Class="pa-3 info-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Symptoms / notes</MudText>
                            <MudText>@(!string.IsNullOrWhiteSpace(_request.Symptoms) ? _request.Symptoms : "Not provided")</MudText>
                        </MudPaper>
                        <MudPaper Class="pa-3 info-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Preferred availability / location</MudText>
                            <MudText>@(!string.IsNullOrWhiteSpace(_request.PreferredAvailability) ? _request.PreferredAvailability : "Not provided")</MudText>
                            <MudText>@(!string.IsNullOrWhiteSpace(_request.VehicleLocation) ? _request.VehicleLocation : "Location not provided")</MudText>
                        </MudPaper>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" lg="7">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" GutterBottom="true">Job status</MudText>
                            <MudSelect @bind-Value="_statusModel.Status" Label="Status" Disabled="_isSaving" Variant="Variant.Outlined">
                                @foreach (var status in ServiceRequestStatuses.All)
                                {
                                    <MudSelectItem Value="@status">@status</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Class="mt-3" Color="Color.Secondary" Variant="Variant.Filled" OnClick="SaveStatusAsync" Disabled="_isSaving" StartIcon="@Icons.Material.Filled.Save">Save status</MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card h-100">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap" Spacing="2">
                                <MudText Typo="Typo.h6">Quote builder</MudText>
                                <MudSpacer />
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">@_quoteModel.CustomerApprovalStatus</MudChip>
                            </MudStack>
                            <MudGrid Spacing="2" Class="mt-1">
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_quoteModel.QuoteTemplate" Label="Quote template" Disabled="_isSaving" Variant="Variant.Outlined">
                                        @foreach (var template in QuoteTemplateOptions.All)
                                        {
                                            <MudSelectItem Value="@template">@template</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="_quoteModel.CustomerApprovalStatus" Label="Customer approval" Disabled="_isSaving" Variant="Variant.Outlined">
                                        @foreach (var approvalStatus in ServiceRequestApprovalStatuses.All)
                                        {
                                            <MudSelectItem Value="@approvalStatus">@approvalStatus</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudDatePicker @bind-Date="_quoteModel.QuoteExpirationDate" Label="Quote expiration" Disabled="_isSaving" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_quoteModel.EstimateLow" Label="Estimate low" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField @bind-Value="_quoteModel.EstimateHigh" Label="Estimate high" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField @bind-Value="_quoteModel.LaborAmount" Label="Labor amount" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField @bind-Value="_quoteModel.PartsAmount" Label="Parts amount" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField @bind-Value="_quoteModel.ShopSuppliesAmount" Label="Shop supplies" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField @bind-Value="_quoteModel.TotalEstimate" Label="Total estimate" Disabled="_isSaving" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudTextField @bind-Value="_availabilityForQuote" Label="Availability to include in quote text" Disabled="_isSaving" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_quoteModel.PartsNeeded" Label="Parts needed" Lines="4" Disabled="_isSaving" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_quoteModel.InternalQuoteNotes" Label="Internal quote notes" Lines="4" Disabled="_isSaving" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_quoteModel.AssumptionDisclaimerText" Label="Assumption / disclaimer text" Lines="3" Disabled="_isSaving" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4"><MudTextField @bind-Value="_quoteModel.GoodOption" Label="Good option" Lines="3" Disabled="_isSaving" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12" md="4"><MudTextField @bind-Value="_quoteModel.BetterOption" Label="Better option" Lines="3" Disabled="_isSaving" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12" md="4"><MudTextField @bind-Value="_quoteModel.BestOption" Label="Best option" Lines="3" Disabled="_isSaving" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12">
                                    <MudTextField Value="@GeneratedQuoteText" Label="Generated customer quote text" Lines="7" ReadOnly="true" Variant="Variant.Outlined" />
                                    <MudButton Class="mt-3 mr-2" Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveQuoteAsync" Disabled="_isSaving" StartIcon="@Icons.Material.Filled.RequestQuote">Save quote</MudButton>
                                    <MudButton Class="mt-3" Color="Color.Secondary" Variant="Variant.Outlined" OnClick="CopyQuoteTextAsync" StartIcon="@Icons.Material.Filled.ContentCopy">Copy quote text</MudButton>
                                    <MudButton Class="mt-3 ml-2" Color="Color.Primary" Variant="Variant.Outlined" OnClick="CopyQuoteLinkAsync" StartIcon="@Icons.Material.Filled.Link">Copy quote approval link</MudButton>
                                    @if (!string.IsNullOrWhiteSpace(_request.CustomerApprovalMessage)) { <MudAlert Severity="Severity.Warning" Class="mt-2">Customer response: @_request.CustomerApprovalMessage</MudAlert> }
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudStack Row="true"><MudText Typo="Typo.h6">Customer links</MudText><MudSpacer/><MudButton OnClick="CopyStatusLinkAsync" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Link">Copy customer status link</MudButton></MudStack></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudText Typo="Typo.h6">Intake answers</MudText>@if(_request.IntakeAnswers.Count==0){<MudText>None provided.</MudText>} else {@foreach(var a in _request.IntakeAnswers){<MudText><b>@a.QuestionText</b>: @(string.IsNullOrWhiteSpace(a.AnswerText)?"Not answered":a.AnswerText)</MudText>}}</MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudText Typo="Typo.h6">Scheduling</MudText><MudGrid><MudItem xs="12" md="4"><MudDatePicker @bind-Date="_scheduledDate" Label="Scheduled date" Variant="Variant.Outlined" /></MudItem><MudItem xs="12" md="4"><MudTextField @bind-Value="_scheduleModel.ServiceLocationType" Label="Location type" Variant="Variant.Outlined" /></MudItem><MudItem xs="12" md="4"><MudNumericField @bind-Value="_scheduleModel.EstimatedDurationMinutes" Label="Duration minutes" Variant="Variant.Outlined" /></MudItem><MudItem xs="12"><MudTextField @bind-Value="_scheduleModel.ScheduleNotes" Label="Schedule notes" Variant="Variant.Outlined" /></MudItem></MudGrid><MudButton OnClick="SaveScheduleAsync" Color="Color.Primary" Variant="Variant.Filled">Save schedule</MudButton></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudText Typo="Typo.h6">Job checklist</MudText>@foreach(var item in _checklist){<MudStack Row="true" AlignItems="AlignItems.Center"><MudCheckBox Value="item.IsCompleted" ValueChanged="@(async (bool v)=> await ToggleChecklistAsync(item, v))" Label="@item.Text" />@if(item.IsCustom){<MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(async()=>await DeleteChecklistAsync(item))" />}</MudStack>}<MudStack Row="true"><MudTextField @bind-Value="_newChecklistText" Label="Add custom item" Variant="Variant.Outlined"/><MudButton OnClick="AddChecklistAsync">Add</MudButton></MudStack></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudText Typo="Typo.h6">Payment</MudText><MudGrid><MudItem xs="12" md="3"><MudSelect @bind-Value="_payment.PaymentStatus" Label="Status" Variant="Variant.Outlined">@foreach(var x in PaymentStatuses.All){<MudSelectItem Value="@x">@x</MudSelectItem>}</MudSelect></MudItem><MudItem xs="12" md="3"><MudSelect @bind-Value="_payment.PaymentMethod" Label="Method" Variant="Variant.Outlined">@foreach(var x in PaymentMethods.All){<MudSelectItem Value="@x">@x</MudSelectItem>}</MudSelect></MudItem><MudItem xs="12" md="3"><MudNumericField @bind-Value="_payment.AmountDue" Label="Amount due" Variant="Variant.Outlined" /></MudItem><MudItem xs="12" md="3"><MudNumericField @bind-Value="_payment.AmountPaid" Label="Amount paid" Variant="Variant.Outlined" /></MudItem><MudItem xs="12"><MudTextField @bind-Value="_payment.Notes" Label="Payment notes" Variant="Variant.Outlined" /></MudItem></MudGrid><MudButton OnClick="SavePaymentAsync" Color="Color.Primary" Variant="Variant.Filled">Save payment</MudButton></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="action-card"><MudCardContent><MudText Typo="Typo.h6">Should I take this job?</MudText><MudChip T="string" Color="@RiskColor" Class="mb-2">Score @_risk.RiskScore: @_risk.Recommendation</MudChip><MudText Typo="Typo.caption">Use this as a guide only. Final decision is yours.</MudText><MudGrid><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.RustConcern" Label="Rust concern" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.RequiresLift" Label="Requires lift" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.CustomerSuppliedParts" Label="Customer parts" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.KnownDifficultVehicle" Label="Difficult vehicle" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.SafetyCritical" Label="Safety critical" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.NeedsAlignment" Label="Needs alignment" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.NeedsTow" Label="Needs tow" /></MudItem><MudItem xs="6" md="3"><MudCheckBox @bind-Value="_risk.MobileWorkConcern" Label="Mobile concern" /></MudItem><MudItem xs="12" md="3"><MudNumericField @bind-Value="_risk.EstimatedHours" Label="Estimated hours" /></MudItem><MudItem xs="12"><MudTextField @bind-Value="_risk.Notes" Label="Risk notes" /></MudItem></MudGrid><MudButton OnClick="SaveRiskAsync" Color="Color.Primary" Variant="Variant.Filled">Save risk</MudButton></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="action-card h-100">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" GutterBottom="true">Internal notes</MudText>
                            <MudTextField @bind-Value="_notesModel.InternalNotes" Label="Internal notes" Lines="9" Disabled="_isSaving" Variant="Variant.Outlined" />
                            <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveNotesAsync" Disabled="_isSaving" StartIcon="@Icons.Material.Filled.StickyNote2">Save notes</MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid RequestId { get; set; }

    private ServiceRequestDto? _request;
    private ServiceRequestStatusUpdateModel _statusModel = new();
    private ServiceRequestQuoteUpdateModel _quoteModel = new();
    private ServiceRequestNotesUpdateModel _notesModel = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private string? _successMessage;
    private AuthState? _authState;
    private string _availabilityForQuote = string.Empty;
    private List<JobChecklistItemDto> _checklist = [];
    private string? _newChecklistText;
    private ServiceRequestScheduleUpdateModel _scheduleModel = new();
    private DateTime? _scheduledDate;
    private PaymentDto _payment = new();
    private JobRiskAssessmentDto _risk = new();
    private Color RiskColor => _risk.Recommendation == RiskRecommendations.GoodFit ? Color.Success : _risk.Recommendation == RiskRecommendations.Maybe ? Color.Warning : Color.Error;

    private string GeneratedQuoteText
    {
        get
        {
            if (_request is null)
            {
                return string.Empty;
            }

            var vehicle = $"{_request.VehicleYear} {_request.VehicleMake} {_request.VehicleModel}".Trim();
            var estimate = FormatEstimateRange();
            var availability = string.IsNullOrWhiteSpace(_availabilityForQuote) ? "the next available opening" : _availabilityForQuote.Trim();
            var service = string.IsNullOrWhiteSpace(_quoteModel.QuoteTemplate) ? _request.ServiceType : _quoteModel.QuoteTemplate;
            var disclaimer = string.IsNullOrWhiteSpace(_quoteModel.AssumptionDisclaimerText)
                ? "assuming no additional issues are found once disassembled."
                : _quoteModel.AssumptionDisclaimerText.Trim();

            var lines = new List<string>
            {
                $"Hey {_request.CustomerName}, I reviewed your request for your {vehicle}.",
                $"My estimate is {estimate} for {service}, {disclaimer}",
                $"I have availability {availability}."
            };

            if (_quoteModel.QuoteExpirationDate is not null)
            {
                lines.Add($"This quote is valid through {_quoteModel.QuoteExpirationDate:MMM d, yyyy}.");
            }

            AddOption(lines, "Good", _quoteModel.GoodOption);
            AddOption(lines, "Better", _quoteModel.BetterOption);
            AddOption(lines, "Best", _quoteModel.BestOption);

            return string.Join(Environment.NewLine, lines);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _authState = await Auth.GetAuthStateAsync();
            if (!_authState.IsAuthenticated || !_authState.IsAdmin)
            {
                return;
            }

            _request = await ServiceRequests.GetByIdAsync(RequestId);
            if (_request is null)
            {
                _errorMessage = "Service request was not found.";
                return;
            }

            ResetModels();
            _checklist = await ServiceRequests.GetChecklistAsync(RequestId);
            _payment = await ServiceRequests.GetPaymentAsync(RequestId);
            _risk = await ServiceRequests.GetRiskAsync(RequestId);
        }
        catch (Exception ex) when (ex is HttpRequestException or InvalidOperationException or JsonException)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Login() => Navigation.NavigateTo("/.auth/login/aad?post_login_redirect_uri=/admin/requests", forceLoad: true);

    private void Logout() => Navigation.NavigateTo("/.auth/logout?post_logout_redirect_uri=/", forceLoad: true);

    private async Task SaveStatusAsync() => await SaveAsync("status", _statusModel, "Status updated.");

    private async Task SaveQuoteAsync() => await SaveAsync("quote", _quoteModel, "Quote updated.");

    private async Task SaveNotesAsync() => await SaveAsync("notes", _notesModel, "Notes updated.");

    private async Task CopyQuoteTextAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", GeneratedQuoteText);
        _successMessage = "Quote text copied to clipboard.";
    }
    private async Task CopyStatusLinkAsync() { await JS.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.ToAbsoluteUri($"/request-status/{_request?.PublicStatusToken}" ).ToString()); _successMessage = "Customer status link copied."; }
    private async Task CopyQuoteLinkAsync() { await JS.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.ToAbsoluteUri($"/quote/{_request?.QuoteApprovalToken}" ).ToString()); _successMessage = "Quote approval link copied."; }
    private async Task SaveScheduleAsync(){ if(_scheduledDate is not null && _scheduleModel.ScheduledStartUtc is null) _scheduleModel.ScheduledStartUtc = DateTime.SpecifyKind(_scheduledDate.Value, DateTimeKind.Local).ToUniversalTime(); await SaveAsync("schedule", _scheduleModel, "Schedule updated."); }
    private async Task SavePaymentAsync(){ _payment = await ServiceRequests.UpdatePaymentAsync(RequestId, _payment); _successMessage="Payment updated."; }
    private async Task SaveRiskAsync(){ _risk = await ServiceRequests.UpdateRiskAsync(RequestId, _risk); _successMessage="Risk assessment updated."; }
    private async Task ToggleChecklistAsync(JobChecklistItemDto item, bool completed){ var updated=await ServiceRequests.UpdateChecklistItemAsync(RequestId,item.Id,new ChecklistItemUpdateModel{IsCompleted=completed}); var i=_checklist.FindIndex(x=>x.Id==item.Id); if(i>=0)_checklist[i]=updated; }
    private async Task AddChecklistAsync(){ if(string.IsNullOrWhiteSpace(_newChecklistText))return; _checklist.Add(await ServiceRequests.AddChecklistItemAsync(RequestId,new ChecklistItemCreateModel{Text=_newChecklistText})); _newChecklistText=null; }
    private async Task DeleteChecklistAsync(JobChecklistItemDto item){ if(!await JS.InvokeAsync<bool>("confirm", $"Remove checklist item '{item.Text}'?")) return; await ServiceRequests.DeleteChecklistItemAsync(RequestId,item.Id); _checklist.Remove(item); }

    private async Task SaveAsync<T>(string segment, T model, string successMessage)
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            _request = segment switch
            {
                "status" => await ServiceRequests.UpdateStatusAsync(RequestId, (ServiceRequestStatusUpdateModel)(object)model!),
                "quote" => await ServiceRequests.UpdateQuoteAsync(RequestId, (ServiceRequestQuoteUpdateModel)(object)model!),
                "notes" => await ServiceRequests.UpdateNotesAsync(RequestId, (ServiceRequestNotesUpdateModel)(object)model!),
                "schedule" => await ServiceRequests.UpdateScheduleAsync(RequestId, (ServiceRequestScheduleUpdateModel)(object)model!),
                _ => throw new InvalidOperationException("Unknown update type.")
            };
            ResetModels();
            _successMessage = successMessage;
        }
        catch (Exception ex) when (ex is HttpRequestException or InvalidOperationException or JsonException)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ResetModels()
    {
        if (_request is null)
        {
            return;
        }

        _statusModel = new ServiceRequestStatusUpdateModel { Status = _request.Status };
        _quoteModel = new ServiceRequestQuoteUpdateModel
        {
            EstimateLow = _request.EstimateLow,
            EstimateHigh = _request.EstimateHigh,
            PartsNeeded = _request.PartsNeeded,
            InternalQuoteNotes = _request.InternalQuoteNotes,
            LaborAmount = _request.LaborAmount,
            PartsAmount = _request.PartsAmount,
            ShopSuppliesAmount = _request.ShopSuppliesAmount,
            TotalEstimate = _request.TotalEstimate ?? CalculateTotalEstimate(),
            QuoteTemplate = string.IsNullOrWhiteSpace(_request.QuoteTemplate) ? QuoteTemplateOptions.GeneralRepair : _request.QuoteTemplate,
            AssumptionDisclaimerText = _request.AssumptionDisclaimerText ?? "assuming no additional issues are found once disassembled.",
            GoodOption = _request.GoodOption,
            BetterOption = _request.BetterOption,
            BestOption = _request.BestOption,
            QuoteExpirationDate = _request.QuoteExpirationDate ?? DateTime.Today.AddDays(14),
            CustomerApprovalStatus = string.IsNullOrWhiteSpace(_request.CustomerApprovalStatus) ? ServiceRequestApprovalStatuses.Pending : _request.CustomerApprovalStatus
        };
        _notesModel = new ServiceRequestNotesUpdateModel { InternalNotes = _request.InternalNotes };
        _availabilityForQuote = _request.PreferredAvailability ?? string.Empty;
        _scheduleModel = new ServiceRequestScheduleUpdateModel { ScheduledStartUtc = _request.ScheduledStartUtc, ScheduledEndUtc = _request.ScheduledEndUtc, EstimatedDurationMinutes = _request.EstimatedDurationMinutes, ServiceLocationType = _request.ServiceLocationType, ScheduleNotes = _request.ScheduleNotes };
        _scheduledDate = _request.ScheduledStartUtc?.ToLocalTime().Date;
    }

    private decimal? CalculateTotalEstimate()
    {
        var total = (_request?.LaborAmount ?? 0) + (_request?.PartsAmount ?? 0) + (_request?.ShopSuppliesAmount ?? 0);
        return total > 0 ? total : null;
    }

    private string FormatEstimateRange()
    {
        if (_quoteModel.EstimateLow is not null && _quoteModel.EstimateHigh is not null)
        {
            return $"{_quoteModel.EstimateLow:C0}–{_quoteModel.EstimateHigh:C0}";
        }

        var estimate = _quoteModel.TotalEstimate ?? _quoteModel.EstimateHigh ?? _quoteModel.EstimateLow;
        return estimate is null ? "TBD" : $"{estimate:C0}";
    }

    private static void AddOption(List<string> lines, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            lines.Add($"{label}: {value.Trim()}");
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        ServiceRequestStatuses.New => Color.Info,
        ServiceRequestStatuses.NeedInfo => Color.Warning,
        ServiceRequestStatuses.Quoted => Color.Primary,
        ServiceRequestStatuses.Scheduled => Color.Secondary,
        ServiceRequestStatuses.PartsOrdered => Color.Tertiary,
        ServiceRequestStatuses.InProgress => Color.Warning,
        ServiceRequestStatuses.Completed => Color.Success,
        ServiceRequestStatuses.Paid => Color.Success,
        ServiceRequestStatuses.Declined => Color.Error,
        ServiceRequestStatuses.Canceled => Color.Error,
        _ => Color.Default
    };
}
