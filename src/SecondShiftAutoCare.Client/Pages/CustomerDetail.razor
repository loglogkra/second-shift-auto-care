@page "/admin/customers/{CustomerId:guid}"
@inject ServiceRequestClient ServiceRequests
<PageTitle>Customer History</PageTitle>
@if(_customer is null){<MudProgressCircular Indeterminate="true"/>} else {<MudText Typo="Typo.h4">@_customer.Name</MudText><MudText>@_customer.Phone @_customer.Email</MudText><MudGrid Class="my-3"><MudItem xs="6" md="3"><MudCard><MudCardContent><MudText Typo="Typo.h5">@_customer.OpenJobs</MudText><MudText>Open jobs</MudText></MudCardContent></MudCard></MudItem><MudItem xs="6" md="3"><MudCard><MudCardContent><MudText Typo="Typo.h5">@_customer.CompletedJobs</MudText><MudText>Completed</MudText></MudCardContent></MudCard></MudItem><MudItem xs="6" md="3"><MudCard><MudCardContent><MudText Typo="Typo.h5">@_customer.TotalEstimatedRevenue.ToString("C0")</MudText><MudText>Estimated</MudText></MudCardContent></MudCard></MudItem><MudItem xs="6" md="3"><MudCard><MudCardContent><MudText Typo="Typo.h5">@_customer.TotalPaidAmount.ToString("C0")</MudText><MudText>Paid</MudText></MudCardContent></MudCard></MudItem></MudGrid><MudText Typo="Typo.h6">Vehicles</MudText>@foreach(var v in _customer.Vehicles){<MudButton Href="@($"/admin/vehicles/{v.Id}")" Variant="Variant.Outlined" Class="ma-1">@v.Year @v.Make @v.Model</MudButton>}<MudText Typo="Typo.h6" Class="mt-4">Requests</MudText><MudTable Items="_customer.Requests"><RowTemplate><MudTd>@context.CreatedAtUtc?.ToLocalTime().ToString("g")</MudTd><MudTd>@context.ServiceType</MudTd><MudTd>@context.Status</MudTd><MudTd><MudButton Href="@($"/admin/requests/{context.Id}")">Open</MudButton></MudTd></RowTemplate></MudTable>}
@code{[Parameter] public Guid CustomerId{get;set;} private CustomerHistoryDto? _customer; protected override async Task OnInitializedAsync()=>_customer=await ServiceRequests.GetCustomerAsync(CustomerId);}
