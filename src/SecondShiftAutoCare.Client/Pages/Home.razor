@page "/"
<PageTitle>2nd Shift Auto Care</PageTitle>

<MudGrid Spacing="4" AlignItems="Center">
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-6 pa-md-8 hero-card" Elevation="3">
            <MudText Typo="Typo.overline" Color="Color.Secondary">Mobile auto care after hours</MudText>
            <MudText Typo="Typo.h3" Class="mt-2" GutterBottom="true">2nd Shift Auto Care</MudText>
            <MudText Typo="Typo.h6" Class="mb-4">Maintenance and common repairs scheduled around your workday.</MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Tell us what your vehicle needs, share your availability, and we will follow up with next steps for oil changes,
                brakes, diagnostics, and other practical service requests.
            </MudText>
            <MudStack Row="true" Spacing="2" Class="flex-wrap">
                <MudButton Href="/request-service" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">Start a request</MudButton>
                <MudButton Href="/admin/requests" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">View requests</MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.h5" GutterBottom="true">Simple MVP workflow</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.EditNote">Submit a service request.</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Schedule">Include your preferred availability.</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Handshake">Get a follow-up before any work begins.</MudListItem>
                </MudList>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="/request-service" Color="Color.Secondary" Variant="Variant.Text">Request service</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>
