@page "/"
<PageTitle>2nd Shift Auto Care</PageTitle>

<MudGrid Spacing="4" AlignItems="Center">
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-5 pa-md-8 hero-card" Elevation="0">
            <MudStack Spacing="3">
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.NightsStay">After-hours and weekend auto service</MudChip>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Place">Zeeland / West Michigan</MudChip>
                </MudStack>
                <MudText Typo="Typo.h3" Class="hero-title">2nd Shift Auto Care</MudText>
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="hero-subtitle">Practical maintenance and common repairs scheduled around your workday.</MudText>
                <MudText Typo="Typo.body1" Class="hero-copy">
                    Submit a request, tell us what is going on with your vehicle, and we will follow up before any work begins.
                    Built for busy drivers who need straightforward service options outside normal shop hours.
                </MudText>
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    <MudButton Href="/request-service" Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large" StartIcon="@Icons.Material.Filled.EditCalendar">Request Service</MudButton>
                    <MudButton Href="/admin/requests" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large" StartIcon="@Icons.Material.Filled.Assignment">Admin Requests</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudStack Spacing="3">
            <MudCard Elevation="0" Class="feature-card">
                <MudCardContent>
                    <MudText Typo="Typo.h5" GutterBottom="true">How it works</MudText>
                    <MudList T="string" Dense="true" Class="clean-list">
                        <MudListItem Icon="@Icons.Material.Filled.EditNote">Send the vehicle, symptoms, and availability.</MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.PhoneInTalk">We review and contact you with next steps.</MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Handshake">You approve the plan before service begins.</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Info">
                MVP portal for Zeeland and West Michigan customers requesting after-hours or weekend service.
            </MudAlert>
        </MudStack>
    </MudItem>
</MudGrid>

<MudGrid Spacing="3" Class="mt-4">
    <MudItem xs="12" sm="4">
        <MudCard Elevation="0" Class="stat-card"><MudCardContent><MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary" /><MudText Typo="Typo.h6">Evening-friendly</MudText><MudText Typo="Typo.body2">Share windows that work after your shift.</MudText></MudCardContent></MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="0" Class="stat-card"><MudCardContent><MudIcon Icon="@Icons.Material.Filled.BuildCircle" Color="Color.Primary" /><MudText Typo="Typo.h6">Common repairs</MudText><MudText Typo="Typo.body2">Oil, brakes, belts, plugs, and diagnostics.</MudText></MudCardContent></MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="0" Class="stat-card"><MudCardContent><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" /><MudText Typo="Typo.h6">Clear follow-up</MudText><MudText Typo="Typo.body2">Status updates keep requests organized.</MudText></MudCardContent></MudCard>
    </MudItem>
</MudGrid>
