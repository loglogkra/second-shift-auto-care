@page "/admin/vehicles/{VehicleId:guid}"
@inject ServiceRequestClient ServiceRequests
<PageTitle>Vehicle History</PageTitle>
@if(_vehicle is null){<MudProgressCircular Indeterminate="true"/>} else {<MudText Typo="Typo.h4">@_vehicle.Year @_vehicle.Make @_vehicle.Model</MudText><MudButton Href="@($"/admin/customers/{_vehicle.CustomerId}")" Variant="Variant.Text">Customer: @_vehicle.CustomerName</MudButton><MudText>Mileage: @(_vehicle.Mileage?.ToString("N0") ?? "Not provided")</MudText><MudText>Last oil change: @(_vehicle.LastOilChange?.ToLocalTime().ToString("d") ?? "Unknown")</MudText><MudText>Last brake job: @(_vehicle.LastBrakeJob?.ToLocalTime().ToString("d") ?? "Unknown")</MudText><MudText Typo="Typo.h6" Class="mt-4">Known issues</MudText>@foreach(var i in _vehicle.KnownIssues){<MudAlert Severity="Severity.Info" Dense="true">@i</MudAlert>}<MudText Typo="Typo.h6" Class="mt-4">Requests</MudText><MudTable Items="_vehicle.Requests"><RowTemplate><MudTd>@context.CreatedAtUtc?.ToLocalTime().ToString("g")</MudTd><MudTd>@context.ServiceType</MudTd><MudTd>@context.Status</MudTd><MudTd>@context.PartsNeeded</MudTd><MudTd><MudButton Href="@($"/admin/requests/{context.Id}")">Open</MudButton></MudTd></RowTemplate></MudTable>}
@code{[Parameter] public Guid VehicleId{get;set;} private VehicleHistoryDto? _vehicle; protected override async Task OnInitializedAsync()=>_vehicle=await ServiceRequests.GetVehicleAsync(VehicleId);}
